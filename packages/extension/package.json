{
  "name": "@password-manager/extension",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension (Chrome + Firefox) for the password manager.",
  "scripts": {
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "BROWSER=chrome vite build",
    "build:firefox": "BROWSER=firefox vite build",
    "dev:chrome": "BROWSER=chrome vite build --watch",
    "dev:firefox": "BROWSER=firefox vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@password-manager/crypto": "*",
    "@password-manager/shared": "*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^6.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  }
}
